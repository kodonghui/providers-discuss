{
  "schema": "providers-discuss.public-config.v1",
  "objective": "Write the public providers-discuss README.md. Cover installation, input folder preparation, provider/seat/round/agent configuration, manual/import execution, and current live-dispatch maturity boundaries clearly.",
  "input": {
    "package_strategy": "local_file_scan",
    "source_dirs": [
      "./sources"
    ]
  },
  "orchestrator": {
    "claim_gate_required": true,
    "read_prior_rounds": true,
    "write_prompt_delta_after_each_round": true
  },
  "agent_catalogs": [
    {
      "enabled": true,
      "id": "kdh-profile-catalog",
      "path": "../../agents/kdh-profile-catalog.json",
      "required": true,
      "type": "kdh_agents_catalog"
    }
  ],
  "agent_profile_defaults": {
    "enabled": false,
    "preset": "balanced-kdh"
  },
  "rounds": [
    {
      "mode": "position",
      "round_id": "R1",
      "title": "README audience, promise, and beginner flow"
    },
    {
      "mode": "challenge",
      "round_id": "R2",
      "title": "Challenge unsupported claims and maturity boundaries"
    },
    {
      "mode": "decide",
      "round_id": "R3",
      "title": "README structure and release gate decision"
    }
  ],
  "seats": [
    {
      "agent_profile_id": "kdh-technical-writer",
      "model": "manual",
      "provider": "manual",
      "reasoning_effort": "manual",
      "required": true,
      "role": "README writer focused on public explanation, onboarding flow, and Korean/English clarity.",
      "seat_id": "readme_writer",
      "timeout_seconds": 2400,
      "transport": "manual"
    },
    {
      "agent_profile_id": "kdh-code-reviewer",
      "model": "manual",
      "provider": "manual",
      "reasoning_effort": "manual",
      "required": true,
      "role": "Package reviewer focused on installation, command examples, and implementation gaps.",
      "seat_id": "package_reviewer",
      "timeout_seconds": 2400,
      "transport": "manual"
    },
    {
      "agent_profile_id": "kdh-qa-verifier",
      "model": "manual",
      "provider": "manual",
      "reasoning_effort": "manual",
      "required": true,
      "role": "Release verifier focused on proof gates, live-adapter caveats, and overclaim prevention.",
      "seat_id": "release_verifier",
      "timeout_seconds": 2400,
      "transport": "manual"
    }
  ]
}
